# Please do not edit this file unless you know what you're doing.
# Your personal options are supposed to be set in .env

# Load and export variables defined in .env and the all the required secrets
dotenv
export KEYBASE=${KEYBASE:-/keybase}
export KBPATH=${KBPATH:-$KEYBASE/private/multiscan/apps/ddns}

export RAILS_MASTER_KEY=$(cat $KBPATH/master.key)
